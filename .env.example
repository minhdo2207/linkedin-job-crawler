# LinkedIn credentials (dùng để login lần đầu)
LINKEDIN_EMAIL=your_email@example.com
LINKEDIN_PASSWORD=your_password

# Browser profile directory (lưu session sau khi login)
BROWSER_PROFILE_DIR=./browser_profile

# Output directory
OUTPUT_DIR=./output

# Số job tối đa mỗi cấp độ
MAX_JOBS_PER_LEVEL=50

# Delay giữa các request (giây) - tránh bị block
DELAY_BETWEEN_REQUESTS=3
